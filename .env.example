# ─── Supabase ────────────────────────────────────────────────────────────────
# Pooled connection (PgBouncer, port 6543) — used by Prisma at runtime
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres"

# Direct connection (port 5432) — used ONLY by: npx prisma migrate deploy
DIRECT_URL="postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres"

# Supabase project credentials
NEXT_PUBLIC_SUPABASE_URL="https://[ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."        # safe to expose — RLS not used
SUPABASE_SERVICE_ROLE_KEY="eyJ..."            # NEVER prefix with NEXT_PUBLIC_

# ─── Auth.js ─────────────────────────────────────────────────────────────────
AUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="https://dinlinks.no"

# ─── Stripe ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_MONTHLY_PRICE_ID="price_..."
STRIPE_YEARLY_PRICE_ID="price_..."

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://dinlinks.no"
